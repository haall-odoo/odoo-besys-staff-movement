<?xml version="1.0"?>
<odoo>
    <record id="staff_movement_type_form_view" model="ir.ui.view">
        <field name="name">staff.movement.type.form</field>
        <field name="model">staff.movement.type</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name" required="1">Name</field>
                        <field name="technical_name" required="1"/>
                        <group>
                            <field name="is_changing_company"/>
                            <field name="is_changing_department"/>
                            <field name="is_changing_position"/>
                        </group>
                        <group>
                            <field name="is_needing_equipment"/>
                            <field name="is_former_employee_link_needed"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>