<?xml version="1.0"?>
<odoo>
    <record id="staff_movement_task_template_form" model="ir.ui.view">
        <field name="name">staff.movement.task.template.form</field>
        <field name="model">staff.movement.task.template</field>
        <field name="arch" type="xml">
            <form>
                <field name="name"/>
                <field name="description"/>
            </form>
        </field>
    </record>

    <record id="staff_movement_task_template_list" model="ir.ui.view">
        <field name="name">staff.movement.task.template.list</field>
        <field name="model">staff.movement.task.template</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="staff_movements_task_menu_action" model="ir.actions.act_window">
        <field name="name">Staff Movements Tasks</field>
        <field name="res_model">staff.movement.task.template</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="staff_movement_task_template_list" />
    </record>
</odoo>