<?xml version="1.0"?>
<odoo>
    <record id="staff_movement_model_list_view" model="ir.ui.view">
        <field name="name">hr.employee.staff.movement.form</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form" />
        <field name="mode">extension</field>
        <field name="arch" type="xml">
            <data string="Channel">
                <xpath expr="//header" position="inside">
                    <button string="Create Movement" name="open_movement_default_wizard" type="object" class="btn"/>
                </xpath>
                <xpath expr="//div[@name='button_box']">
                    <button name="action_open_logs"
                        class="oe_stat_button"
                        icon="fa-shield"
                        type="object"
                        >
                        <div class="o_stat_info">
                            Staff Movements
                            <span class="o_stat_value">
                                <field name="versions_count"/>
                            </span>
                        </div>
                    </button>
                </xpath>
                <xpath expr="//notebook" position="inside">
                    <page name="Staff Movement">
                        <field name="staff_movement_ids" readonly="True"/>
                    </page>
                </xpath>
            </data>
        </field>
    </record>

    <record id="staff_movements_list" model="ir.ui.view">
        <field name="name">staff.movement.list</field>
        <field name="model">staff.movement</field>
        <field name="arch" type="xml">
            <list decoration-muted="not active">
                <field name="employee_id" column_invisible="not context.get('show_employee_col')"/>
                <field name="effective_date"/>
                <field name="movement_type_id"/>
                <field name="actual_company_id"/>
                <field name="actual_position_id"/>

                <button name="mark_as_done" 
                    string="Mark Done" 
                    type="object" 
                    icon="fa-bars" 
                    class="btn-link"
                    invisible="is_done or not active"
                    />

                <button name="mark_as_cancelled" 
                    string="Cancel" 
                    type="object" 
                    icon="fa-bars" 
                    class="btn-link"
                    invisible="is_done or not active"
                    />
            </list>
        </field>
    </record>

    <record id="staff_movement_form" model="ir.ui.view">
        <field name="name">staff.movement.form</field>
        <field name="model">staff.movement</field>
        <field name="arch" type="xml">
            <form delete="0">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <field name="profile_picture" nolabel="1" widget="image" class="m-0" options="{'size': [128,128], 'zoom': false, 'preview_image':'profile_picture', 'img_class': 'border rounded h-100 object-fit-contain'}"/>

                    <group>
                        <group>
                            <field name="employee_id" readonly="id"/>
                            <field name="actual_company_id" readonly="1"/>
                            <field name="actual_department_id" readonly="1"/>
                            <field name="actual_position_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="movement_type_id" readonly="0"/>
                            <field name="effective_date"/>
                            <field name="is_equipment_needed"
                                invisible="not is_needing_equipment"
                                />
                            <field name="keyboard_layout"
                                invisible="not is_equipment_needed"
                                />
                            <field name="new_company_id" 
                                invisible="not is_changing_company" 
                                required="is_changing_company"
                                />
                            <field name="new_department_id"
                                invisible="not is_changing_department"
                                required="is_changing_department"
                                />
                            <field name="new_position_id"
                                invisible="not is_changing_position"
                                required="is_changing_position"
                                />
                            <field name="former_employee_id"
                                invisible="not is_former_employee_link_needed"
                                required="is_former_employee_link_needed"
                                />
                        </group>                            
                    </group>
                    <notebook>
                        <page name="Remark">
                            <field name="remark" type="html" options="{'collaborative': true, 'resizable': false}" placeholder="Add details about this staff movement..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter reload_on_follower="True"/>
            </form>
        </field>
    </record>

    <record id="view_staff_movement_search" model="ir.ui.view">
        <field name="name">staff.movement.search</field>
        <field name="model">staff.movement</field>
        <field name="arch" type="xml">
            <search string="Staff Movements">
                <field name="employee_id"/>
                <field name="actual_position_id"/>
                <group>
                    <filter string="Arrivals" name="filter_arrivals" domain="[('movement_type_id.technical_name', 'ilike', 'hired')]"/>
                    <filter string="Change of Position" name="filter_change_of_position" domain="[('movement_type_id.technical_name', 'ilike', 'change_of_position')]"/>
                    <filter string="Departures" name="filter_departures" domain="[('movement_type_id.technical_name', 'ilike', 'departure')]"/>
                </group>
                <group>
                    <filter string="Active" name="filter_active" domain="[('active', '=', True)]"/>
                    <filter string="Archived" name="filter_archived" domain="[('active', '=', False)]"/>
                </group>
            </search>
        </field>
    </record>

    <record id="staff_movements_menu_action" model="ir.actions.act_window">
        <field name="name">Staff Movements</field>
        <field name="res_model">staff.movement</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_staff_movement_search"/>
        <field name="context">{
            'active_test': False,
            'search_default_filter_active': 1,
            'show_employee_col': 1,
            'group_by': 'movement_type_id',
        }</field>
        <field name="domain">[("is_done", "=", False)]</field>
        <field name="view_id" ref="staff_movements_list" />
    </record>

    <record id="action_fire_batch_employee" model="ir.actions.server">
        <field name="name">Fire Employee(s)</field>
        <field name="model_id" ref="hr.model_hr_employee"/>
        <field name="binding_model_id" ref="hr.model_hr_employee"/>
        <field name="binding_view_types">list,kanban</field>
        <field name="state">code</field>
        <field name="code">
if records:
    action = records.open_wizard_staff_departure()
        </field>
    </record>
</odoo>