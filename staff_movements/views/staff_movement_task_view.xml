<?xml version="1.0"?>
<odoo>
    <record id="staff_movement_task_form" model="ir.ui.view">
        <field name="name">staff.movement.task.form</field>
        <field name="model">staff.movement.task</field>
        <field name="arch" type="xml">
            <form>
                <field name="name"/>
                <field name="description"/>
            </form>
        </field>
    </record>

    <record id="staff_movement_task_list" model="ir.ui.view">
        <field name="name">staff.movement.task.list</field>
        <field name="model">staff.movement.task</field>
        <field name="arch" type="xml">
            <list decoration-success="state" decoration-muted="not active">
                <field name="name"/>
                <field name="state" invisible="1"/>
                <field name="active" invisible="1"/>

                <button name="mark_as_done" 
                    string="Mark Done" 
                    type="object" 
                    icon="fa-bars" 
                    class="btn-link"
                    invisible="state or not active"
                    />

                <button name="mark_as_cancelled" 
                    string="Cancel" 
                    type="object" 
                    icon="fa-bars" 
                    class="btn-link"
                    invisible="state or not active"
                    />
            </list>
        </field>
    </record>
</odoo>