<?xml version="1.0"?>
<odoo>
    <record id="staff_movement_default_wizard" model="ir.ui.view">
        <field name="name">staff.movement.default.wizard.form</field>
        <field name="model">staff.movement.default.wizard</field>
        <field name="arch" type="xml">
            <form string="Create a staff movement">
                <sheet>
                    <group>
                        <field name="employee_id" required="1"/>
                        <field name="movement_type" required="1"/>
                        <field name="effective_date" required="1"/>
                    </group>
                </sheet>
                <footer>
                    <button string="Validate" name="action_wizard" type="object" class="btn-primary"/>
                    <button string="Discard" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>