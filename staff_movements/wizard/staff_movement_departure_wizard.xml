<?xml version="1.0"?>
<odoo>
    <record id="staff_movement_departure_wizard" model="ir.ui.view">
        <field name="name">staff.movement.departure.wizard.form</field>
        <field name="model">staff.movement.departure.wizard</field>
        <field name="arch" type="xml">
            <form string="Confirm departure(s)">
                <sheet>
                    <group>
                        <field name="date" required="1"/>
                    </group>
                </sheet>
                <footer>
                    <button string="Validate" name="action_wizard" type="object" class="btn-primary"/>
                    <button string="Discard" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>